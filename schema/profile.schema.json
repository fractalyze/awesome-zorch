{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://awesome-zorch.dev/schema/profile.schema.json",
  "title": "awesome-zorch benchmark profile",
  "type": "object",
  "required": ["id", "board", "field_class", "degree", "device", "columns"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9^-]*$" },
    "board": { "enum": ["PCS", "Hash", "Zkvm", "Sumcheck", "MSM", "FFT"] },
    "field_class": { "type": "string" },
    "degree": { "type": "string" },
    "device": { "type": "string" },
    "columns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["key", "label", "unit", "lower"],
        "properties": {
          "key": { "type": "string" },
          "label": { "type": "string" },
          "unit": { "type": "string" },
          "lower": { "type": "boolean" },
          "primary": { "type": "boolean" }
        }
      }
    }
  }
}
  