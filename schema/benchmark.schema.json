{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "per-library benchmark stats",
  "description": "Maintainer-only measured numbers for one library. See design.md §3.",
  "type": "object",
  "required": ["library", "stats"],
  "additionalProperties": false,
  "properties": {
    "library": { "type": "string", "description": "must equal filename and an existing library id" },
    "stats": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["label"],
        "additionalProperties": false,
        "oneOf": [
          { "required": ["value", "unit"], "not": { "required": ["text"] } },
          { "required": ["text"], "not": { "required": ["value"] } }
        ],
        "properties": {
          "label": { "type": "string", "description": "what was measured" },
          "value": { "type": "number" },
          "unit": { "type": "string", "description": "×, s, ms, MB/s, …" },
          "text": { "type": "string", "description": "non-numeric milestone stat, e.g. 'First working GPU implementation'" },
          "baseline": { "type": "string", "description": "comparison phrasing, e.g. 'vs upstream SP1'" },
          "device": { "type": "string" },
          "note": { "type": "string", "description": "methodology one-liner" },
          "featured": { "type": "boolean", "description": "shown on the library card / home" }
        }
      }
    }
  }
}
